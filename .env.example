# Copy to .env and fill in. .env is gitignored.
#
# The test scripts read these from the ENVIRONMENT (they don't auto-load this
# file). Either export them in your shell, or source this file:
#   set -a; source .env; set +a

# Required for the Gemini-based test harness (scripts/run_*.py).
GOOGLE_API_KEY=

# Required. Shell-split command the harness runs to compile the spec. Scripts
# append the project dir + flags (--format, --language, --vars-file). Point
# --prefix at a flowstore checkout; collapses to "flowstore-compile" once the
# published CLI ships.
FLOWSTORE_COMPILE_CMD=npm --prefix /path/to/flowstore -w @flowstore/core run --silent flowstore-compile --
